  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.22.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "eslint": "^10.7.0",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-solid": "^2.11.12",
