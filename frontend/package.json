{
  "name": "timetracker-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "lint": "eslint .",
    "typecheck": "bun run i18n:compile && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.37.1",
    "@solidjs/router": "~0.16.1",
    "@tanstack/solid-query": "^5.101.0",
    "solid-js": "~1.9.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.20.1",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-symfony": "^8.2.4",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
