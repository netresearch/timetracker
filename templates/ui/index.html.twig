{# JSON_HEX_* flags so |json_encode output cannot break out of <script> #}
{% set jsonHexFlags = constant('JSON_HEX_TAG') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_QUOT') %}
<!DOCTYPE html>
<html lang="{{ locale }}">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{{ apptitle }}</title>
        {% include 'partials/theme-init.html.twig' %}
        {% include 'partials/density-init.html.twig' %}
        {% include 'partials/font-init.html.twig' %}
        {% include 'partials/nav-layout-init.html.twig' %}
        {{ vite_entry_link_tags('app') }}
        <script>
            {# csrfToken + loginPath power the in-place re-login overlay (issue #408):
               the 'authenticate' token is stateless, so it — and the CSRF cookie this
               render sets — survive a session that expires while the SPA is open. #}
            window.APP_CONFIG = {{ {
                'locale': locale,
                'userId': settings.user_id,
                'userName': settings.user_name,
                'appTitle': apptitle,
                'roles': settings.roles,
                'showEmptyLine': settings.show_empty_line == 1,
                'suggestTime': settings.suggest_time == 1,
                'showFuture': settings.show_future == 1,
                'minEntryDuration': settings.min_entry_duration,
                'totpEnabled': settings.totp_enabled,
                'localAccount': settings.local_account,
                'logoutUrl': logout_url(),
                'csrfToken': csrf_token('authenticate'),
                'loginPath': path('_login'),
            }|json_encode(jsonHexFlags)|raw }};
        </script>
        {{ vite_entry_script_tags('app') }}
    </head>
    <body>
        {% include 'partials/header.html.twig' %}
        <div id="app"></div>
    </body>
</html>
