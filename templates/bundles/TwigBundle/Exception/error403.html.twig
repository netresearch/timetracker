<!DOCTYPE HTML>
<html lang="{{ app.request and app.request.locale ? app.request.locale : 'en' }}">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>Access Denied - TimeTracker</title>
        <meta name="robots" content="noindex,nofollow" />
        {% include 'partials/theme-init.html.twig' %}
        {# Self-contained inline styles (no Vite bundle on error pages), using
           the app's light-dark() palette so the page follows the saved theme. #}
        <style>
            :root {
                color-scheme: light dark;
            }
            :root[data-theme=light] {
                color-scheme: light;
            }
            :root[data-theme=dark] {
                color-scheme: dark;
            }
            body {
                /* plain-color fallbacks precede light-dark() for browsers
                   without support (docs/FAQ.md baseline) */
                background-color: #e4e6e8;
                background-color: light-dark(#e4e6e8, #171a1f);
                color: #1f2937;
                color: light-dark(#1f2937, #f1f2f4);
                font-family: Arial, sans-serif;
                font-size: 13px;
                margin: 0;
                padding: 0;
            }
            .error-container {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: #fff;
                background: light-dark(#fff, #1d2127);
                border: 1px solid #c3c8cd;
                border: 1px solid light-dark(#c3c8cd, #3c434b);
                border-radius: 10px;
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
                width: 400px;
                max-width: 90%;
            }
            .error-header {
                border-bottom: 1px solid #c3c8cd;
                border-bottom: 1px solid light-dark(#c3c8cd, #3c434b);
                padding: 12px 16px;
                font-weight: 600;
                color: #00525c;
                color: light-dark(#00525c, #6fd0dd);
                border-radius: 10px 10px 0 0;
            }
            .error-body {
                padding: 20px;
                text-align: center;
            }
            .error-icon {
                font-size: 48px;
                color: #b00000;
                color: light-dark(#b00000, #e0888c);
                margin-bottom: 15px;
            }
            .error-message {
                font-size: 14px;
                margin-bottom: 20px;
                line-height: 1.5;
            }
            .error-actions {
                margin-top: 20px;
            }
            .btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-height: 44px;
                padding: 0 20px;
                margin: 0 5px;
                background: transparent;
                border: 1px solid #a9adb2;
                border: 1px solid light-dark(#a9adb2, #3a414a);
                border-radius: 8px;
                color: #3a4047;
                color: light-dark(#3a4047, #c4c9cf);
                text-decoration: none;
                font-size: 13px;
                cursor: pointer;
            }
            .btn:hover,
            .btn:focus-visible {
                background-color: rgba(0, 136, 154, 0.1);
                background-color: light-dark(rgba(0, 136, 154, 0.1), rgba(111, 208, 221, 0.12));
                color: #00525c;
                color: light-dark(#00525c, #6fd0dd);
            }
            .btn:focus-visible {
                outline: 2px solid #00889a;
                outline: 2px solid light-dark(#00889a, #6fd0dd);
                outline-offset: 1px;
            }
            .btn-primary {
                background: #00889a;
                background: light-dark(#00889a, #0f3a40);
                border-color: #00707f;
                border-color: light-dark(#00707f, #6fd0dd);
                color: #fff;
                color: light-dark(#fff, #6fd0dd);
            }
            .btn-primary:hover,
            .btn-primary:focus-visible {
                background: #00707f;
                background: light-dark(#00707f, #14494f);
                color: #fff;
                color: light-dark(#fff, #6fd0dd);
            }
        </style>
    </head>
    <body>
        <div class="error-container">
            <div class="error-header">
                Access Denied
            </div>
            <div class="error-body">
                <div class="error-icon">&#9888;</div>
                <div class="error-message">
                    You don't have permission to access this page.
                    {% if exception.message is defined and exception.message != 'Access Denied.' %}
                        <br><br>
                        <small>{{ exception.message }}</small>
                    {% endif %}
                </div>
                <div class="error-actions">
                    <a href="{{ path('_start') }}" class="btn btn-primary">Go to Homepage</a>
                    {# logout_path() needs firewall/request context, which the
                       global error handler rendering this page does not have —
                       append the stateless token manually instead. #}
                    <a href="{{ path('_logout') }}?_csrf_token={{ csrf_token('logout') }}" class="btn">Logout</a>
                </div>
            </div>
        </div>
    </body>
</html>
